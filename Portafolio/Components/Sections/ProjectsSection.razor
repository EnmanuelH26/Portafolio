@code {
    [Parameter]
    public Project[] Projects { get; set; } = Array.Empty<Project>();
}

<section class="section" id="proyectos">
    <div class="section-header">
        <p class="eyebrow">Proyectos</p>
        <h2>Trabajo reciente</h2>
        <p>Una muestra de proyectos donde participe en estrategia, diseno y desarrollo.</p>
    </div>
    <div class="project-grid">
        @foreach (var project in Projects)
        {
            <article class="project-card">
                <div class="project-top">
                    <span class="chip">@project.Type</span>
                    <span class="project-year">@project.Year</span>
                </div>
                <h3>@project.Title</h3>
                <p>@project.Description</p>
                <div class="project-tags">
                    @foreach (var tag in project.Stack)
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
                <div class="project-footer">
                    <span class="muted">@project.Role</span>
                    @if (!string.IsNullOrWhiteSpace(project.Link))
                    {
                        <a class="text-link" href="@project.Link" target="_blank" rel="noreferrer noopener">@project.LinkLabel ?? "Ver proyecto"</a>
                    }
                    else
                    {
                        <span class="muted">Privado</span>
                    }
                </div>
            </article>
        }
    </div>
</section>

