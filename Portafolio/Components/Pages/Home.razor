@page "/"

<PageTitle>Portafolio | Enmanuel</PageTitle>

<section class="hero" id="inicio">
    <div class="hero-content">
        <p class="eyebrow">Disponible para nuevos proyectos</p>
        <h1>Hola, soy <span>Enmanuel Hernandez</span>. Transformo ideas en productos digitales claros y medibles.</h1>
        <p class="lead">
            Desarrollo experiencias web centradas en negocio: desde estrategia hastaa implementacion y lanzamiento.
        </p>
        <div class="hero-actions">
            <a class="button primary" href="#proyectos">Ver proyectos</a>
            <a class="button ghost" href="#contacto">Hablemos</a>
        </div>
        <div class="hero-metrics">
            <div class="metric">
                <strong>+5</strong>
                <span>Proyectos entregados</span>
            </div>
            <div class="metric">
                <strong>5</strong>
                <span>Industrias diferentes</span>
            </div>
            <div class="metric">
                <strong>100%</strong>
                <span>Enfoque en impacto</span>
            </div>
        </div>
    </div>
    <div class="hero-card">
        <p class="eyebrow">Resumen rapido</p>
        <h2>Lo que puedo liderar</h2>
        <ul class="checklist">
            <li>Direccion de producto y discovery rapido.</li>
            <li>Desarrollo frontend con performance y accesibilidad.</li>
            <li>Integracion con APIs, dashboards y automatizaciones.</li>
        </ul>
        <div class="hero-card-footer">
            <span>Base: Santo Domingo, RD</span>
            <span>Trabajo remoto o hibrido</span>
        </div>
    </div>
</section>

<section class="section about" id="sobre-mi">
    <div class="section-header">
        <p class="eyebrow">Sobre mi</p>
        <h2>Trabajo de extremo a extremo para que cada entrega tenga impacto real.</h2>
        <p>
            Combino estrategia, diseno y desarrollo para lanzar productos digitales consistentes.
            Mi objetivo es entregar soluciones claras, medibles y faciles de mantener.
        </p>
    </div>
    <div class="about-grid">
        <div class="about-card">
            <h3>Enfoque</h3>
            <p>
                Descubro el problema real, diseno la experiencia y entrego una solucion lista para crecer.
                Priorizo velocidad con calidad tecnica.
            </p>
        </div>
        <div class="about-card">
            <h3>Entregables</h3>
            <div class="tag-grid">
                <span class="tag">Research rapido</span>
                <span class="tag">Design system</span>
                <span class="tag">UI Kit</span>
                <span class="tag">Frontend</span>
                <span class="tag">APIs</span>
                <span class="tag">Analytics</span>
            </div>
        </div>
    </div>
</section>

<section class="section" id="proyectos">
    <div class="section-header">
        <p class="eyebrow">Proyectos</p>
        <h2>Trabajo reciente</h2>
        <p>Una muestra de proyectos donde participe en estrategia, diseno y desarrollo.</p>
    </div>
    <div class="project-grid">
        @foreach (var project in Projects)
        {
            <article class="project-card">
                <div class="project-top">
                    <span class="chip">@project.Type</span>
                    <span class="project-year">@project.Year</span>
                </div>
                <h3>@project.Title</h3>
                <p>@project.Description</p>
                <div class="project-tags">
                    @foreach (var tag in project.Stack)
                    {
                        <span class="tag">@tag</span>
                    }
                </div>
                <div class="project-footer">
                    <span class="muted">@project.Role</span>
                    @if (!string.IsNullOrWhiteSpace(project.Link))
                    {
                        <a class="text-link" href="@project.Link" target="_blank" rel="noreferrer">@project.LinkLabel ?? "Ver proyecto"</a>
                    }
                    else
                    {
                        <span class="muted">Privado</span>
                    }
                </div>
            </article>
        }
    </div>
</section>

<section class="section" id="habilidades">
    <div class="section-header">
        <p class="eyebrow">Habilidades</p>
        <h2>Stack y especialidades</h2>
        <p>Herramientas y areas en las que me muevo con soltura.</p>
    </div>
    <div class="skills-grid">
        @foreach (var group in SkillGroups)
        {
            <div class="skill-card">
                <h3>@group.Title</h3>
                <div class="tag-grid">
                    @foreach (var item in group.Items)
                    {
                        <span class="tag">@item</span>
                    }
                </div>
            </div>
        }
    </div>
</section>

<section class="section contact" id="contacto">
    <div class="section-header">
        <p class="eyebrow">Contacto</p>
        <h2>Construyamos algo juntos</h2>
        <p>Comparte tu idea y preparare una propuesta clara de alcance y tiempos.</p>
    </div>
    <div class="contact-grid">
        @foreach (var contact in ContactLinks)
        {
            <a class="contact-card" href="@contact.Url" target="_blank" rel="noreferrer">
                <span class="contact-label">@contact.Label</span>
                <span class="contact-value">@contact.Value</span>
                <span class="contact-action">Abrir</span>
            </a>
        }
    </div>
    <div class="cta-banner">
        <div>
            <h3>Listo para tu siguiente lanzamiento</h3>
            <p>Agenda una llamada corta para entender el proyecto.</p>
        </div>
        <a class="button primary" href="mailto:tuemail@dominio.com">Escribeme</a>
    </div>
</section>

